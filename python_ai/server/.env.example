# Copy to .env and/or .env.test in this directory (python_ai/server/).
# Flask loads .env first, then .env.test (overrides). Commit neither file.
#
# Engine: libm4engine.dylib / .so only in python_ai/lib/ or python_ai/libs/ (from git release/submodule/CI — not ../c-lib).
#
# M4_APP_MONGO_URI=mongodb://127.0.0.1:27017/?directConnection=true
# M4_APP_MONGO_DB=product
# M4ENGINE_MONGO_URI=mongodb://127.0.0.1:27017/
#
# Engine chat → c-lib uses mongo_uri for server + hardcoded DB ``bot`` (STORAGE_CHAT_DB).
# Store / SharedCollection ELK backfill → defaults: shared_collection_mongo_uri from M4_APP_MONGO_URI
# (else same as M4ENGINE_MONGO_URI), shared_collection_backfill_db from M4_APP_MONGO_DB (else ``product``).
#
# SharedCollection → c-lib ``api_options_t.shared_collection_json_path`` (Python maps env; c-lib does not call getenv).
# ELK mode + es_host: default file is generated under server/data/shared_collection_registry.json from shared_collection_catalog.
# Override with absolute path:
# M4_SHARED_COLLECTION_JSON=/path/to/registry.json
# M4ENGINE_SHARED_COLLECTION_JSON=/path/to/registry.json   # alias
# Optional admin overrides: bot_c_lib_settings (shared_collection_* keys).
# JWT_SECRET=change-me
# AUTH_SEED_DEFAULT_PASSWORD=12345678@Ab
#
# --- SSE stream (python_ai/server/stream_chat_backends.py + chat_stream_callbacks.md) ---
# Chat SSE: use M4_CHAT_STREAM_MODE only (NOT DEFAULT_CHAT_STREAM_MODE — that constant is code-only).
# Omit or leave empty → router (hosted Groq/Cerebras/Gemini try + Ollama fallback per M4_CHAT_BACKEND).
# M4_CHAT_STREAM_MODE=ollama   # c-lib api_chat_stream only (local Ollama)
# M4_CHAT_STREAM_MODE=router   # explicit same as default
# M4_CHAT_BACKEND=cloud_then_ollama  # default — router tries hosted then Ollama
# M4_CHAT_BACKEND=ollama             # router: Ollama stream only (skip Groq/Cerebras/Gemini)
# M4_CHAT_BACKEND=cloud              # router: hosted only; error if all tiers fail
#
# --- Hosted LLM (same env for POST /api/chat and SSE router; defaults match c-lib cloud_llm.c) ---
# M4_CHAT_BACKEND=cloud_then_ollama
# M4_CLOUD_TRY_ORDER=groq,cerebras,gemini
# M4_CLOUD_GROQ_MODEL=llama-3.1-8b-instant
# M4_CLOUD_CEREBRAS_MODEL=llama3.1-8b
# M4_CLOUD_GEMINI_MODEL=gemini-2.0-flash
# CEREBRAS_API_BASE=https://api.cerebras.ai/v1
# Optional SSE overrides (same semantics if set): M4_CLOUD_GROQ_CHAT_COMPLETIONS_URL,
# M4_CLOUD_CEREBRAS_CHAT_COMPLETIONS_URL, M4_CLOUD_GEMINI_GENERATE_URL with {model}
#
# Paste your real keys below (one line each, no quotes):
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# GEMINI_API_KEY=
#
# --- Debug logging (c-lib debug_log.h) ---
# INFO/WARN/ERROR are always logged to stderr. DEBUG level requires listing modules here.
# Comma-separated module keys. Omit or empty = no DEBUG logs.
# M4_DEBUG_MODULES=API,ai_agent,STORAGE,GEO_LEARNING,GEO_AUTH,OLLAMA,ELK,EMBED_MIGRATION,ENGINE,CHAT,nl_learn_terms,LOGIC_CONFLICT
#
# --- Initial prompt tags (set at api_create, not per-request) ---
# M4_DEFAULT_PERSONA=       # system persona; empty = compiled-in default
# M4_DEFAULT_INSTRUCTIONS=  # extra system text before chat history
# M4_DEFAULT_MODEL_LANE=0   # 0=DEFAULT, 1=EDUCATION, 2=BUSINESS, 3=TECH, 4=CHAT
